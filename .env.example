# ===========================================
# OPC-Starter 环境变量模板
# 复制此文件为 .env.local 并填入真实值
# ===========================================

# ---- Supabase ----
# Supabase 项目 URL（从 Supabase Dashboard > Settings > API 获取）
VITE_SUPABASE_URL=https://your-project.supabase.co
# Supabase 匿名公钥（anon/public key）
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---- MSW Mock 模式 ----
# 设为 true 启用 MSW 拦截，无需真实 Supabase（本地开发推荐）
# VITE_ENABLE_MSW=true

# ---- Mock 数据 ----
# 启用后使用本地 mock 数据代替远程数据
# VITE_MOCK_DATA_ENABLED=true

# ---- 日志级别 ----
# 可选值: debug | info | warn | error
# VITE_LOG_LEVEL=info
